# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/agenti"
DIRECT_URL="postgresql://user:password@localhost:5432/agenti"

# Auth (required)
NEXTAUTH_SECRET="your-random-secret-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3001"

# Admin
ADMIN_EMAILS="admin@example.com"
ADMIN_ALERT_EMAILS="admin@example.com"

# R2 Storage - S3-compatible (Cloudflare R2)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="agents"
R2_ENDPOINT="https://your-bucket.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://your-bucket.r2.cloudflarestorage.com"

# Wallet/Chain (required for blockchain features)
NEXT_PUBLIC_MARKETPLACE_ADDRESS="0x..."
NEXT_PUBLIC_ESCROW_ADDRESS="0x..."
NEXT_PUBLIC_LICENSE_ADDRESS="0x..."
PLATFORM_PRIVATE_KEY="0x..."

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# Stripe (optional - for payments)
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email alerts (optional - for agent reports)
RESEND_API_KEY="re_..."
RESEND_FROM="Alerts <alerts@yourdomain.com>"

# Cron jobs (for Vercel scheduled functions)
CRON_SECRET="your-cron-secret-min-32-chars"